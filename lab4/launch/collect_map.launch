<launch>
    <!-- TO USE THIS TO COLLECT MAP, RUN WITH TELEOP, THEN USE MAPSAVER -->
     
    <!-- Arguments -->
    <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
    <param name="tb3_model" value="$(arg model)"/>

    <!-- Gmapping -->
    <node pkg="gmapping" type="slam_gmapping" name="turtlebot3_slam_gmapping" output="screen">
        <param name="base_frame" value="base_footprint" />
        <param name="odom_frame" value="odom" />
        <param name="map_frame" value="map" />
        <rosparam command="load" file="$(find lab4)/config/general_gmapping_params.yaml" />
    </node>


    <!-- TurtleBot3 -->
    <include file="$(find turtlebot3_bringup)/launch/turtlebot3_remote.launch">
        <arg name="model" value="$(arg model)"/>
    </include>


    <!-- Rviz -->
    <node pkg="rviz" type="rviz" name="rviz" output="screen" args="-d $(find lab4)/rviz/gmappingConfig.rviz"/>

    <arg name="multi_robot_name" default=""/>   

    <!-- Launch path planner -->
    <node name="path_planner" pkg="lab3" type="path_planner.py" output="screen" />

     <!-- Launch lab3 listener -->
    <node name="lab3_listener" pkg="lab3" type="lab3_listener.py" />

    <!-- Launch lab2 pure pursuit node -->
    <!-- <node name="PurePursuit" pkg="lab2" type="lab2.py" output="screen"/> -->

    <!-- runs frontier node -->
    <node name="Frontier_Exp" pkg="lab4" type="frontier.py" output="screen" />


</launch>



  

