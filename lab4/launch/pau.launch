<launch>
    <!--gmapping. We don't need mapserver if gmapping is running -->
    <include file="$(find turtlebot3_slam)/launch/turtlebot3_slam.launch" />

    <!-- runs frontier node-->
    <node name="Frontier_Exp" pkg="lab4" type="frontier.py" output="screen" />

    <!-- pulls up a world-->
    <include file="$(find lab4)/launch/world_sim.launch">
        <arg name="model" value="burger"/>
        <arg name="world" value="turtlebot"/>
    </include>

</launch>