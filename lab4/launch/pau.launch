<launch>
    <!-- mapping. We don't need mapserver if gmapping is running -->
    <include file="$(find turtlebot3_slam)/launch/turtlebot3_slam.launch" />
    
    <!-- runs frontier node -->
    <node name="Frontier_Exp" pkg="lab4" type="frontier.py" output="screen" />

    <!-- pulls up a world -->
    <include file="$(find lab4)/launch/world_sim.launch">
        <arg name="model" value="burger"/>
        <arg name="world" value="turtlebot"/>
    </include>


    <!-- Launch path planner -->
    <node name="path_planner" pkg="lab3" type="path_planner.py" output="screen" />

     <!-- Launch lab3 listener -->
    <node name="lab3_listener" pkg="lab3" type="lab3_listener.py" />

    <!-- Launch lab2 pure pursuit node -->
    <node name="PurePursuit" pkg="lab2" type="lab2.py"/>



</launch>